{% extends 'base.html.twig' %}

{% block title %}Hello ItemController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>
    
    <div  class="example-wrapper text-center">
        {% for category in categories %}
        <a  href="{{ path('app_item_by_category', {id: category.id}) }}" class="text-decoration-none">
            <span class="badge rounded-pill bg-dark">
                {{ category.name }}
            </span>
        </a>
        {% endfor %}
    </div>


    <div class=" d-flex flex-wrap gap-3 justify-content-center">
        {% for item in items %}
            <div class="card bg-light mb-3" style="max-width: 20rem;">
                <div class="card-header">{{ item.startingPrice }}$</div>
                <div class="card-body">
                    <h4 class="card-title">{{ item.title }}</h4>
                    <a href="{{ path('app_item_show', {id: item.id}) }}" class="card-text text-decoration-none">Voir le détail</a>
                </div>
                <div class="card-footer text-muted">
                    status: {{ item.statusLabel }}
                </div>
            </div> 
        {% endfor %}
    </div>

    
{% endblock %}
